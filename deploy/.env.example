# ============================================
# simior-blog 环境变量配置模板
# 复制本文件为 .env 并填写实际值：cp .env.example .env
# ============================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=change_me_mysql_root_password

# ---- MinIO 对象存储 ----
MINIO_ACCESS_KEY=change_me_minio_access_key
MINIO_SECRET_KEY=change_me_minio_secret_key

# ---- 阿里云 OSS（可选，mode=oss 时使用）----
OSS_ENDPOINT=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET_NAME=

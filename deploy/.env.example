# ============================================
# simior-blog 环境变量配置模板
#
# 使用方法：
#   1. 复制此文件：cp .env.example .env
#   2. 编辑配置：nano .env
#   3. 重新部署：cd docker && docker compose up -d --build
#
# 注意：修改配置后需要重新部署才会生效
# ============================================

# ============================================
# 数据库配置
# ============================================

# MySQL root 密码（修改后记得更新）
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# MySQL 端口映射到宿主机
# 留空 = 不暴露到宿主机（更安全，只能容器内部访问）
# 填 3306 = 暴露到宿主机（可以用 Navicat 等工具远程连接）
DB_PORT_EXPOSE=

# ============================================
# Redis 配置
# ============================================

# Redis 端口映射到宿主机
# 留空 = 不暴露到宿主机
REDIS_PORT_EXPOSE=

# ============================================
# MinIO 文件存储配置
# ============================================

# MinIO 管理员账号（控制台登录用）
MINIO_ACCESS_KEY=admin

# MinIO 管理员密码（控制台登录用）
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET

# MinIO API 端口（程序调用）
MINIO_API_PORT=9000

# MinIO 控制台端口（浏览器管理界面）
MINIO_CONSOLE_PORT=9001

# ============================================
# 后端配置
# ============================================

# 文件上传模式
# minio = 使用 MinIO 存储（默认，本地部署推荐）
# oss = 使用阿里云 OSS（需要配置阿里云密钥）
BLOG_UPLOAD_MODE=minio

# CORS 跨域配置
# * = 允许所有来源（开发测试用）
# 填具体域名 = 只允许指定域名访问（生产环境推荐）
# 例：https://blog.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=*

# ============================================
# Nginx 配置
# ============================================

# Nginx 监听端口
# 80 = HTTP 默认端口（浏览器访问时不用加端口号）
# 改成 8080 = 访问时需要加端口号：http://IP:8080
NGINX_PORT=80

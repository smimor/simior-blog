# ============================================
# blog-web 前台 Dockerfile
#
# 多阶段构建：
#   第 1 步：用 Node.js 编译 Next.js 代码
#   第 2 步：用 Node.js 运行 standalone 服务器
#
# 构建命令：docker build -f deploy/docker/Dockerfile.web -t simior-web .
# ============================================

# ---- 第 1 步：编译构建 ----
# 钉死大版本号，避免 node:latest 未来大版本升级悄悄弄坏构建
FROM node:22-slim AS builder
WORKDIR /app

# 安装 pnpm（blog-web 用 pnpm 管理依赖，与 Dockerfile.admin 保持一致）
RUN npm install -g pnpm --registry=https://registry.npmmirror.com

# 复制 package.json + pnpm 锁文件 + workspace 配置
# workspace 配置里的 allowBuilds: sharp 用于放行 sharp 的构建脚本，
# 缺了它 pnpm 10 默认不运行依赖的构建脚本，Next.js 图片优化会缺失原生二进制
COPY blog-web/package.json blog-web/pnpm-lock.yaml blog-web/pnpm-workspace.yaml blog-web/

# 安装依赖
# pnpm install --frozen-lockfile：严格按 pnpm-lock.yaml 安装，锁文件与
# package.json 不一致时直接报错，保证构建可复现（等价于 npm ci）
RUN cd blog-web && pnpm install --frozen-lockfile --registry=https://registry.npmmirror.com

# 复制源码并构建
# Next.js 的 NEXT_PUBLIC_* 变量必须在构建时注入
ARG NEXT_PUBLIC_API_URL=/api
ARG NEXT_PUBLIC_SITE_NAME=Simior Blog
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_SITE_NAME=$NEXT_PUBLIC_SITE_NAME
COPY blog-web/ blog-web/
RUN cd blog-web && pnpm run build

# ---- 第 2 步：运行 ----
# 使用 standalone 模式：Next.js 会生成一个独立的 Node.js 服务器
# 不需要 Nginx，自带 HTTP 服务器
FROM node:22-slim
LABEL maintainer="simior"

# 创建非 root 用户
RUN addgroup --system app && adduser --system --ingroup app app

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# 复制 standalone 服务器文件
COPY --from=builder /app/blog-web/.next/standalone ./
# 复制静态资源（JS、CSS、图片等）
COPY --from=builder /app/blog-web/.next/static ./.next/static
# 复制 public 目录（favicon 等）
COPY --from=builder /app/blog-web/public ./public

EXPOSE 3000

USER app

# 启动 Next.js standalone 服务器
CMD ["node", "server.js"]

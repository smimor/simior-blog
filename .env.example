# ============================================
# simior-blog 环境变量配置模板
# 复制本文件为 .env 并填写实际值：cp .env.example .env
# ============================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=change_me_mysql_root_password
MYSQL_PORT=3306

# ---- Redis ----
REDIS_PORT=6379

# ---- MinIO 对象存储 ----
MINIO_ACCESS_KEY=change_me_minio_access_key
MINIO_SECRET_KEY=change_me_minio_secret_key
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- 后端服务 ----
SERVER_PORT=8080

# ---- 前端管理后台 ----
ADMIN_PORT=80

# ---- CORS 跨域（逗号分隔多个域名）----
# 生产环境请填写实际的前端访问地址
CORS_ALLOWED_ORIGINS=http://YOUR_SERVER_IP

# ---- 阿里云 OSS（生产环境可选，mode=oss 时使用）----
OSS_ENDPOINT=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET_NAME=

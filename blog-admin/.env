# ============================================
# blog-admin 环境变量
#
# VITE_ 前缀的变量会暴露给浏览器端
# 用于配置前端运行时的行为
# ============================================

# 应用版本号（显示在控制台）
VITE_VERSION=3.0.2

# 开发服务器端口（仅本地开发时使用）
VITE_PORT=3006

# 应用部署基础路径
# / = 根路径（通过 Nginx 反向代理时使用）
VITE_BASE_URL=/

# 权限模式
# frontend = 前端控制（角色在前端定义）
# backend = 后端控制（角色在后端定义）
VITE_ACCESS_MODE=frontend

# 跨域请求时是否携带 Cookie
# true = 携带（需要后端支持 CORS credentials）
# false = 不携带
VITE_WITH_CREDENTIALS=false
